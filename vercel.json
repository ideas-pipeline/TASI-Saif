{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm turbo run build --filter=@sultan-saif/web",
  "outputDirectory": "apps/web/.next",
  "ignoreCommand": "exit 1",
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 6 * * *"
    }
  ]
}
