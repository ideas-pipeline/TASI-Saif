{"nodes": [{"id": "_claude_skills_graphify_references_query_query_expansion", "label": "Constrained Query Expansion", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The query matcher is case-folded substring + IDF with no stemming, synonyms, or cross-language matching, so vocabulary mismatch collapses answers to noise. The fix expands the question against tokens actually present in graph labels - never inventing tokens - and prints the selection so the expansion is auditable."}, {"id": "_claude_skills_graphify_references_query_graph_traversal", "label": "BFS/DFS Graph Traversal", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "BFS (default) for broad context questions, DFS (depth-limited to 6) for tracing a specific chain; output is token-budget aware, ranked by term relevance and truncated at ~4 chars/token."}, {"id": "_claude_skills_graphify_references_query_shortest_path", "label": "Shortest Path Query (/graphify path)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_node_explain", "label": "Node Explain (/graphify explain)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_references_query_work_memory", "label": "Work Memory (save-result Loop)", "file_type": "concept", "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Self-improving loop: every query/path/explain answer is saved back with an outcome (useful/dead_end/corrected), and graphify reflect distills them into LESSONS.md listing preferred sources, known dead ends, and corrections that future sessions read at start."}], "edges": [{"source": "_claude_skills_graphify_references_query_query_expansion", "target": "_claude_skills_graphify_references_query_graph_traversal", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": "query.md Step 1", "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_graph_traversal", "target": "_claude_skills_graphify_references_query_work_memory", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_shortest_path", "target": "_claude_skills_graphify_references_query_work_memory", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_node_explain", "target": "_claude_skills_graphify_references_query_work_memory", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": null, "weight": 1.0}, {"source": "_claude_skills_graphify_references_query_work_memory", "target": "_claude_skills_graphify_references_update_incremental_update", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/query.md", "source_location": "query.md: the next --update extracts this Q&A as a node", "weight": 1.0}], "hypere