{"nodes": [{"id": "_claude_skills_graphify_skill_graphify_pipeline", "label": "Graphify Pipeline", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Turns any folder of code/docs/papers/images/video into a persistent, queryable knowledge graph with an honest audit trail; community detection surfaces cross-document connections users would not think to ask about."}, {"id": "_claude_skills_graphify_skill_community_detection", "label": "Community Detection", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_god_nodes", "label": "God Nodes", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_ast_structural_extraction", "label": "AST Structural Extraction", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic and free: code is extracted via AST with no LLM and no API key, so a code-only corpus skips semantic extraction entirely. Run in parallel with semantic subagents to save 5-15s on large corpora."}, {"id": "_claude_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction Subagents", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Docs/papers/images need LLM extraction; parallel general-purpose subagents (chunks of 20-25 files, dispatched in one message) are 5-10x faster than reading files serially. Explore-type agents are forbidden because they are read-only and silently drop chunk files."}, {"id": "_claude_skills_graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cache entries are attributed to the extraction prompt file (SPEC_PATH): when a graphify upgrade changes the prompt, old entries are re-extracted instead of replayed; unchanged prompts keep their entries (#1939)."}, {"id": "_claude_skills_graphify_skill_audit_trail", "label": "EXTRACTED/INFERRED/AMBIGUOUS Audit Trail", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_honesty_rules", "label": "Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent an edge (use AMBIGUOUS when unsure), never skip corpus warnings, always show token cost, show raw cohesion scores, warn before visualizing graphs over 5000 nodes."}, {"id": "_claude_skills_graphify_skill_graph_health_check", "label": "Graph Health Check", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Read-only integrity gate before labeling; surfaces edge collapse, dangling/missing endpoints, and self-loops - the silent-corruption modes of incremental updates and AST/LLM id mismatches. Never aborts, but warnings must be surfaced per the Honesty Rules."}, {"id": "_claude_skills_graphify_skill_fast_path_query", "label": "Fast Path Query on Existing Graph", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When graphify-out/graph.json exists and the request is a natural-language question, skip the entire build pipeline and run graphify query immediately - the graph is already built."}, {"id": "_claude_skills_graphify_skill_shrink_guard", "label": "Graph Shrink Guard", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "to_json refuses to write when the new graph is smaller than the existing graph.json (#479), and GRAPH_REPORT.md is only written when the graph was actually written, so reports never describe a graph that graph.json does not contain (#1392)."}, {"id": "_claude_skills_graphify_skill_cost_tracker", "label": "Cumulative Cost Tracker", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_claude_skills_graphify_skill_gemini_backend", "label": "Gemini Backend Fallback", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "graphify needs no API key and must never block on one: Gemini is used only if GEMINI_API_KEY/GOOGLE_API_KEY is already set; otherwise the host agent itself is the LLM. No other provider keys are read."}], "edges": [{"source": "_claude_skills_graphify_skill_graphify_pipeline", "target": "_claude_skills_graphify_skill_ast_structural_extraction", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "SKILL.md Step 3 Part A", "weight": 1.0}, {"source": "_claude_skills_graphify_s