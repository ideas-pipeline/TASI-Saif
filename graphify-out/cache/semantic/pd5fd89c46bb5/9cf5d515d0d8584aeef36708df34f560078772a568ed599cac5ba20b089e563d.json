{"nodes": [{"id": "_claude_skills_graphify_references_extraction_spec_subagent_prompt", "label": "Extraction Subagent Prompt", "file_type": "concept", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Loaded only when a chunk holds docs/papers/images; a pure-code corpus never reads it. source_file must be copied verbatim from FILE_LIST so full builds and incremental --update stay on the same base and build_merge replace-on-re-extract matches existing nodes."}, {"id": "_claude_skills_graphify_references_extraction_spec_confidence_rubric", "label": "Discrete Confidence Rubric", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Models follow discrete rubrics better than continuous ranges: production showed a bimodal collapse (>50% at 0.5, >40% at 0.85+), so INFERRED scores are restricted to five fixed values (0.95/0.85/0.75/0.65/0.55) and 0.5 is banned."}, {"id": "_claude_skills_graphify_references_extraction_spec_node_id_format", "label": "Full-Path Node ID Format", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "IDs use the full repo-relative path stem so same-named files in different directories stay distinct and semantic IDs match AST-generated IDs; filename-only or parent-only stems create orphan ghost-duplicate nodes. IDs must be deterministic - never append chunk suffixes."}, {"id": "_claude_skills_graphify_references_extraction_spec_hyperedges", "label": "Hyperedges", "file_type": "concept", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url"