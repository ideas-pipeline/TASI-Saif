{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pip install --quiet graphifyy 2>/dev/null || true",
            "timeout": 300,
            "statusMessage": "Installing graphifyy..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/graphify hook-guard search"
          }
        ]
      },
      {
        "matcher": "Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/graphify hook-guard read"
          }
        ]
      }
    ]
  }
}