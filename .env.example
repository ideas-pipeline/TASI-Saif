# =============================================================================
# sultan-saif — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sultan_saif

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Auth ---
BETTER_AUTH_SECRET=change-this-to-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# --- Scheduled Generation ---
CRON_SECRET=change-this-to-a-random-secret

# --- App ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NODE_ENV=development
PORT=8000
