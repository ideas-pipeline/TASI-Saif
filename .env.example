# TASI Platform Environment Configuration

# Alpha Vantage API key (free tier: 25 requests/day, 5 requests/minute)
ALPHA_VANTAGE_API_KEY=your_key_here

# Database path (defaults to ./data/tasi.db)
# TASI_DB_PATH=./data/tasi.db

# API server port (defaults to 3000)
# TASI_PORT=3000

# Anthropic API key for AI scoring (optional)
# ANTHROPIC_API_KEY=
