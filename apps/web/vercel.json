{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm --filter @sultan-saif/shared run build && pnpm run build",
  "ignoreCommand": "exit 1",
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 6 * * *"
    }
  ]
}
